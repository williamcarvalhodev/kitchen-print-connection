{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./frontend/src/*"]
    }
  },
  "include": ["src/**/*", "frontend/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
